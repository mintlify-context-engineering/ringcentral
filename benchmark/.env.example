# Copy this file to .env and fill in your key.
#   cp .env.example .env

# Cursor API key — powers all three roles when running with --provider cursor:
#   1. raw monorepo agent  2. Mintlify-docs agent (via MCP)  3. judge
# Get yours at https://cursor.com/dashboard/integrations
CURSOR_API_KEY=crsr-your-cursor-api-key-here

# OpenRouter API key — powers all three roles when running with --provider openrouter
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key-here

# Optional OpenRouter model defaults
OPENROUTER_MODEL=~openai/gpt-latest
OPENROUTER_JUDGE_MODEL=~openai/gpt-latest

# Mintlify-hosted RingCentral docs MCP server (override only if it moves)
MINTLIFY_MCP_URL=https://ringcentral.mintlify.app/mcp
