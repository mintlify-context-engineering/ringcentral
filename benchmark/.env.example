# Copy this file to .env and fill in your key.
#   cp .env.example .env

# Cursor API key — powers all three roles in the benchmark:
#   1. raw monorepo agent  2. Mintlify-docs agent (via MCP)  3. judge
# Get yours at https://cursor.com/dashboard/integrations
CURSOR_API_KEY=crsr_paste_your_key_here

# Mintlify-hosted RingCentral docs MCP server (override only if it moves)
MINTLIFY_MCP_URL=https://ringcentral.mintlify.app/mcp
